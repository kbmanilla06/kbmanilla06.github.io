# Portfolio contact form — pick ONE path below. Without either, the
# form still renders and validates, but submissions return a friendly
# "not configured" message instead of attempting to send anything.

# Option A: Resend (recommended — resend.com, free tier, no domain
# verification needed if sending from onboarding@resend.dev)
RESEND_API_KEY=

# Option B: SMTP fallback (e.g. Gmail with an App Password — requires
# 2FA enabled on the account to generate one)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional — overrides the default recipient (defaults to the address in
# lib/content/profile.ts)
CONTACT_TO_EMAIL=

# Public production origin used for canonical links, social cards, and sitemap.
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
